<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:JustFileComparer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="JustFileComparer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        WindowStartupLocation="CenterOwner"
        WindowState="Normal"
        CanResize="False"
        SizeToContent="Manual"
        Height="360"
        Width="440"
        Icon="/Assets/avalonia-logo.ico"
        Title="JustFileComparer">

    <Design.Height>360</Design.Height>
    <Design.Width>440</Design.Width>
    <Design.DataContext><vm:MainWindowViewModel/></Design.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Stretch">
            <Label Content="{Binding AppInfo}" HorizontalAlignment="Center" FontSize="9" />
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0 5" HorizontalAlignment="Stretch">
            <Label Content="Source Root" HorizontalAlignment="Left" />
            <TextBox Text="{Binding SourceRoot, Mode=TwoWay}"  />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0 5">
            <Label Content="Target Root" HorizontalAlignment="Left" />
            <TextBox Text="{Binding TargetRoot, Mode=TwoWay}"  />
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0 10" Orientation="Horizontal">
            <TextBlock Margin="0 0 10 0" Text="File Comparison Mode: " VerticalAlignment="Center"/>
            <CheckBox Padding="10 0" Content="Size" IsChecked="{Binding DoCompareBySize}"/>
            <CheckBox Padding="10 0" Content="Hash" IsChecked="{Binding DoCompareByHash}"/>
            <CheckBox Padding="10 0" Content="Bytes" IsChecked="{Binding DoCompareByBytes}"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Compare" HorizontalAlignment="Center"
                    Command="{Binding Compare}"/>
            <Button Content="Cancel" HorizontalAlignment="Center"
                    Command="{Binding CancelCompare}"/>
        </StackPanel>

        <Label Grid.Row="4" 
               HorizontalAlignment="Right"
               VerticalAlignment="Center"
               Content="Canceling..."
               IsVisible="{Binding IsCanceled}"/>

        <StackPanel Grid.Row="5" Margin="0 10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Elapsed Time: "/>
                <TextBlock Text="{Binding ElapsedTime}" HorizontalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Found Files Count: "/>
                <TextBlock Text="{Binding TotalFilesCount}" HorizontalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Comparisons Count: "/>
                <TextBlock Text="{Binding TotalComparisonsCount}" HorizontalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Successful Comparisons Count: "/>
                <TextBlock Text="{Binding SuccessfulComparisonsCount}" HorizontalAlignment="Center" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Failed Comparisons Count: "/>
                <TextBlock Text="{Binding FailedComparisonsCount}" HorizontalAlignment="Center" />
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="6">
            <TextBlock Text="{Binding Status, Mode=OneWay}" HorizontalAlignment="Center"  />
        </StackPanel>

    </Grid>

</Window>
